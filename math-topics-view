<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Project Prometheus — Quant Math Map</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:        #0e0f11;
    --surface:   #16181c;
    --surface2:  #1e2026;
    --border:    rgba(255,255,255,0.07);
    --border2:   rgba(255,255,255,0.12);
    --text:      #e8e6df;
    --muted:     #8a8880;
    --faint:     #4a4845;

    --tier-a-bg: #1e1a38; --tier-a-text: #c8c3f8; --tier-a-dot: #7f77dd;
    --tier-b-bg: #0d2820; --tier-b-text: #7dd9bc; --tier-b-dot: #1d9e75;
    --tier-c-bg: #2a1108; --tier-c-text: #f0a07a; --tier-c-dot: #d85a30;
    --tier-d-bg: #241600; --tier-d-text: #f8c46a; --tier-d-dot: #ef9f27;
    --tier-e-bg: #041d38; --tier-e-text: #85c8f5; --tier-e-dot: #378add;
    --tier-f-bg: #1a0d28; --tier-f-text: #d4a0f8; --tier-f-dot: #9f60d4;
    --tier-h-bg: #0e2204; --tier-h-text: #a8d870; --tier-h-dot: #639922;
    --tier-i-bg: #280d1c; --tier-i-text: #f0a0c8; --tier-i-dot: #d4537e;
    --tier-j-bg: #1a1a18; --tier-j-text: #c8c6be; --tier-j-dot: #888780;
    --tier-m-bg: #141412; --tier-m-text: #909088; --tier-m-dot: #666460;

    --accent: #5b8fff;
    --radius: 8px;
    --font-mono: 'DM Mono', monospace;
    --font-sans: 'DM Sans', sans-serif;
  }

  html { font-size: 15px; }
  body { background: var(--bg); color: var(--text); font-family: var(--font-sans); line-height: 1.6; min-height: 100vh; }

  /* ── Layout ── */
  .page { max-width: 900px; margin: 0 auto; padding: 3rem 1.5rem 5rem; }

  /* ── Header ── */
  .header { margin-bottom: 2.5rem; }
  .header-eyebrow {
    font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.12em;
    color: var(--accent); text-transform: uppercase; margin-bottom: 0.6rem;
  }
  .header h1 { font-size: 1.7rem; font-weight: 500; color: var(--text); letter-spacing: -0.02em; line-height: 1.2; }
  .header p { color: var(--muted); font-size: 0.9rem; margin-top: 0.5rem; max-width: 520px; line-height: 1.6; }

  /* ── Legend ── */
  .legend { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 1.5rem; }
  .legend-item {
    display: flex; align-items: center; gap: 5px;
    font-size: 11px; color: var(--muted); font-family: var(--font-mono);
  }
  .legend-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }

  /* ── Filters ── */
  .filter-row { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 1.8rem; }
  .filter-btn {
    padding: 5px 13px; border-radius: 20px; cursor: pointer; transition: all 0.15s ease;
    font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.04em;
    background: var(--surface); color: var(--muted);
    border: 1px solid var(--border2);
  }
  .filter-btn:hover { color: var(--text); border-color: rgba(255,255,255,0.25); }
  .filter-btn.active { background: var(--accent); color: #fff; border-color: var(--accent); }

  /* ── Section ── */
  .section { margin-bottom: 1rem; border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; }
  .section-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 12px 16px; cursor: pointer; user-select: none;
    background: var(--surface); transition: background 0.12s;
  }
  .section-header:hover { background: var(--surface2); }
  .section-title { display: flex; align-items: center; gap: 10px; font-size: 13px; font-weight: 500; color: var(--text); }
  .section-icon { font-size: 14px; }
  .section-count {
    font-family: var(--font-mono); font-size: 10px; color: var(--muted);
    background: var(--surface2); border: 1px solid var(--border2);
    padding: 1px 7px; border-radius: 10px;
  }
  .chevron { color: var(--faint); font-size: 11px; transition: transform 0.2s; }
  .collapsed .chevron { transform: rotate(-90deg); }
  .section-body { border-top: 1px solid var(--border); }

  /* ── Row ── */
  .row {
    display: grid; grid-template-columns: 210px 1fr;
    padding: 9px 16px; gap: 12px; align-items: start;
    border-bottom: 1px solid var(--border);
    transition: background 0.1s;
  }
  .row:last-child { border-bottom: none; }
  .row:hover { background: rgba(255,255,255,0.02); }
  .math-topic { font-size: 12.5px; color: var(--muted); padding-top: 3px; font-family: var(--font-mono); line-height: 1.4; }
  .projects { display: flex; flex-wrap: wrap; gap: 5px; }

  /* ── Tags ── */
  .tag {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 3px 10px; border-radius: 20px; font-size: 11px; font-weight: 400;
    font-family: var(--font-mono); white-space: nowrap; letter-spacing: 0.01em;
    border: 1px solid transparent;
  }
  .tag-dot { width: 5px; height: 5px; border-radius: 50%; flex-shrink: 0; }

  .tag.tier-a { background: var(--tier-a-bg); color: var(--tier-a-text); }
  .tag.tier-a .tag-dot { background: var(--tier-a-dot); }
  .tag.tier-b { background: var(--tier-b-bg); color: var(--tier-b-text); }
  .tag.tier-b .tag-dot { background: var(--tier-b-dot); }
  .tag.tier-c { background: var(--tier-c-bg); color: var(--tier-c-text); }
  .tag.tier-c .tag-dot { background: var(--tier-c-dot); }
  .tag.tier-d { background: var(--tier-d-bg); color: var(--tier-d-text); }
  .tag.tier-d .tag-dot { background: var(--tier-d-dot); }
  .tag.tier-e { background: var(--tier-e-bg); color: var(--tier-e-text); }
  .tag.tier-e .tag-dot { background: var(--tier-e-dot); }
  .tag.tier-f { background: var(--tier-f-bg); color: var(--tier-f-text); }
  .tag.tier-f .tag-dot { background: var(--tier-f-dot); }
  .tag.tier-h { background: var(--tier-h-bg); color: var(--tier-h-text); }
  .tag.tier-h .tag-dot { background: var(--tier-h-dot); }
  .tag.tier-i { background: var(--tier-i-bg); color: var(--tier-i-text); }
  .tag.tier-i .tag-dot { background: var(--tier-i-dot); }
  .tag.tier-j { background: var(--tier-j-bg); color: var(--tier-j-text); }
  .tag.tier-j .tag-dot { background: var(--tier-j-dot); }
  .tag.tier-m { background: var(--tier-m-bg); color: var(--tier-m-text); border-color: var(--border2); }
  .tag.tier-m .tag-dot { background: var(--tier-m-dot); }

  /* ── Footer ── */
  .footer { margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid var(--border); font-size: 11px; font-family: var(--font-mono); color: var(--faint); display: flex; justify-content: space-between; flex-wrap: wrap; gap: 6px; }

  @media (max-width: 600px) {
    .row { grid-template-columns: 1fr; }
    .math-topic { padding-top: 0; }
    .header h1 { font-size: 1.3rem; }
  }
</style>
</head>
