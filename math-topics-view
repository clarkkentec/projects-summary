function buildLegend() {
  const el = document.getElementById('legend');
  el.innerHTML = TIERS.map(t => `
    <div class="legend-item">
      <div class="legend-dot" style="background:${t.dot}"></div>
      ${t.label}
    </div>`).join('');
}

function buildFilters() {
  const el = document.getElementById('filters');
  el.innerHTML = FILTERS.map(f => `
    <button class="filter-btn${f.id==='all'?' active':''}" data-filter="${f.id}">${f.label}</button>
  `).join('');
  el.addEventListener('click', e => {
    const btn = e.target.closest('.filter-btn');
    if (!btn) return;
    el.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    render(btn.dataset.filter);
  });
}

function tag(p) {
  return `<span class="tag tier-${p.tier}"><span class="tag-dot"></span>${p.label}</span>`;
}

function render(filter) {
  const content = document.getElementById('content');
  content.innerHTML = '';
  DATA.forEach(section => {
    if (filter !== 'all' && filter !== section.id) return;
    const wrap = document.createElement('div');
    wrap.className = 'section';

    const header = document.createElement('div');
    header.className = 'section-header';
    header.innerHTML = `
      <div class="section-title">
        <span class="section-icon">${section.icon}</span>
        <span>${section.label}</span>
        <span class="section-count">${section.rows.length} topics</span>
      </div>
      <span class="chevron">▼</span>`;
    header.addEventListener('click', () => {
      header.classList.toggle('collapsed');
      body.style.display = header.classList.contains('collapsed') ? 'none' : 'block';
    });

    const body = document.createElement('div');
    body.className = 'section-body';
    section.rows.forEach(row => {
      const r = document.createElement('div');
      r.className = 'row';
      r.innerHTML = `
        <div class="math-topic">${row.topic}</div>
        <div class="projects">${row.projects.map(tag).join('')}</div>`;
      body.appendChild(r);
    });

    wrap.appendChild(header);
    wrap.appendChild(body);
    content.appendChild(wrap);
  });
}

buildLegend();
buildFilters();
render('all');
